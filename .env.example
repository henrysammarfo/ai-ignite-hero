# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SQUADS_MULTISIG_AUTHORITY=your-squads-multisig-pubkey

# Solana / Helius Infrastructure
VITE_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key
SOLANA_PRIVATE_KEY=your-base58-private-key

# Compliance Logic
# Set to 'true' to enable mock data for local testing
VITE_USE_MOCKS=false
VITE_SOLSTICE_MOCK=false
VITE_SOLSTICE_API_KEY=your-solstice-api-key
SOLSTICE_API_KEY=your-solstice-api-key

# Squads Grid (custody) mock/API
VITE_GRID_MOCK=true
VITE_SQUADS_GRID_API_KEY=your-grid-api-key

# OAuth / Identity
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: local OpenAI key for edge functions (kyc-internal)
OPENAI_API_KEY=your-openai-key
